{
  "name": "csp-hash-from-html",
  "version": "0.3.1",
  "description": "Generate hashes from inline scripts and styles in HTML file to be used in Content-Security-Policy header.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/apaatsio/csp-hash-from-html.git"
  },
  "main": "dist/lib.js",
  "bin": {
    "csp-hash": "dist/cli.js"
  },
  "scripts": {
    "build": "rolldown -c",
    "test": "vitest run",
    "test-coverage": "vitest run --coverage"
  },
  "keywords": [
    "csp",
    "security"
  ],
  "author": "Antti Ahti <antti.ahti@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "rolldown": "^1.0.0-rc.12",
    "rolldown-plugin-dts": "^0.22.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
