// Jest Snapshot v1, https://jestjs.io/docs/snapshot-testing

exports[`cli prints help with -h 1`] = `
"Usage: cli [options] <fileOrGlob ...>

Generate hashes from inline scripts and styles in HTML file to be used in
Content-Security-Policy header.

Options:
  -V, --version                output the version number
  -a, --algorithm <algorithm>  hash algorithm (choices: "sha256", "sha384",
                               "sha512", default: "sha256")
  -d, --directive <directive>  directive (choices: "default-src", "script-src",
                               "style-src")
  --debug                      verbose output for debugging
  -h, --help                   display help for command

  Examples:

    $ csp-hash index.html
    $ csp-hash index.html example.html
    $ csp-hash build/**/*.html
    $ csp-hash -a sha512 index.html
    $ csp-hash -d script-src index.html

"
`;

exports[`cli prints verbose output with --debug 1`] = `
"Passed arguments:
globArg:
 ./test/fixtures/simple-script.html
options:
 {
  "algorithm": "sha256",
  "debug": true
}
Final options:
{
  "algorithm": "sha256",
  "directive": "default-src",
  "debug": true
}
Discovered files (1 files):
test/fixtures/simple-script.html
default-src: 'sha256-gaaMFNHZyRta8zB2VHkWLMP4tMxJ+d8v3dTW7nw2r6M=';
"
`;
